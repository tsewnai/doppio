# Turso Database
# For local dev, DATABASE_URL can be a local SQLite file: file:./local.db
# For production, use your Turso database URL: libsql://your-db.turso.io
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000
